{
  "name": "hello-gen-ai",
  "type": "module",
  "private": true,
  "workspaces": [
    "openai/*",
    "google/*"
  ],
  "scripts": {
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --deny-warnings . --fix",
    "fmt": "oxfmt --write openai/ google/",
    "fmt:check": "oxfmt --check openai/ google/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.13",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}