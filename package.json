{
  "name": "hello-gen-ai",
  "type": "module",
  "private": true,
  "workspaces": [
    "openai/*",
    "google/*"
  ],
  "scripts": {
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --deny-warnings . --fix",
    "fmt": "oxfmt --write openai/ google/",
    "fmt:check": "oxfmt --check openai/ google/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "1.3.14",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6.0.0"
  }
}